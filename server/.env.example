PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/callshot
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# 'production' on deploy — enables serving client static files
NODE_ENV=development

# On Railway/Render: set to your deployed frontend URL (or same URL if serving from server)
# For local dev: http://localhost:5173 or comma-separated list e.g. http://localhost:5173,http://192.168.x.x:5173
CLIENT_URL=http://localhost:5173

# Email (SMTP) — use Gmail App Password or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=CallShot <your_email@gmail.com>
