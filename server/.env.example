PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/callshot
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

NODE_ENV=development

# On Render: set to your deployed Vercel frontend URL
# For local dev: http://localhost:5173 or comma-separated e.g. http://localhost:5173,http://192.168.x.x:5173
CLIENT_URL=http://localhost:5173

# Email — uses Brevo (https://brevo.com). Free tier: 300 emails/day.
# 1. Sign up at brevo.com
# 2. Verify your sender email: Settings → Senders & IPs → Senders
# 3. Get API key: Settings → SMTP & API → API Keys
BREVO_API_KEY=your_brevo_api_key_here
SMTP_FROM_EMAIL=your_verified_sender@gmail.com
SMTP_FROM_NAME=CallShot
