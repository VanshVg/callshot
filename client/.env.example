# API base URL — used in production when NOT proxying through Vite
# In development, leave this blank and configure VITE_API_PROXY_TARGET in .env instead
# In production (Vercel/Netlify): set to your deployed backend URL e.g. https://callshot-api.railway.app/api
VITE_API_URL=

# Dev proxy target — Vite will forward /api requests to this URL
# Default: http://localhost:5000 (change to your local machine IP for LAN testing)
VITE_API_PROXY_TARGET=http://localhost:5000
